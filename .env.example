# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio

# ── Auth service ──────────────────────────────────────────────────────────────
AUTH_DATABASE_URL=postgresql+asyncpg://auth:auth_pass@postgres-auth:5432/auth_db
AUTH_SECRET_KEY=changeme_auth_secret_at_least_32_chars
# Generate RSA keys: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@consulting-pm.local

# ── Projects service ──────────────────────────────────────────────────────────
PROJECTS_DATABASE_URL=postgresql+asyncpg://projects:projects_pass@postgres-projects:5432/projects_db
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio
MINIO_BUCKET_ATTACHMENTS=attachments
MINIO_USE_SSL=false

# ── Timelog service ───────────────────────────────────────────────────────────
TIMELOG_DATABASE_URL=postgresql+asyncpg://timelog:timelog_pass@postgres-timelog:5432/timelog_db

# ── Billing service ───────────────────────────────────────────────────────────
BILLING_DATABASE_URL=postgresql+asyncpg://billing:billing_pass@postgres-billing:5432/billing_db
TIMELOG_SERVICE_URL=http://timelog:8003

# ── Resources service ─────────────────────────────────────────────────────────
RESOURCES_DATABASE_URL=postgresql+asyncpg://resources:resources_pass@postgres-resources:5432/resources_db

# ── Notifications service ─────────────────────────────────────────────────────
NOTIFICATIONS_DATABASE_URL=postgresql+asyncpg://notifications:notif_pass@postgres-notifications:5432/notifications_db

# ── Shared (all services) ─────────────────────────────────────────────────────
REDIS_URL=redis://:changeme_redis@redis:6379/0
LOG_LEVEL=INFO
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
